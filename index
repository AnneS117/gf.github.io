    <script>
        // Lösung ein-/ausblenden
        function toggleLoesung(button) {
            const loesung = button.nextElementSibling;
            if (loesung.classList.contains('show')) {
                loesung.classList.remove('show');
                button.textContent = 'Lösung anzeigen';
            } else {
                loesung.classList.add('show');
                button.textContent = 'Lösung verbergen';
            }
        }

        // Multiple Choice überprüfen
        function checkQuiz(button) {
            const quiz = button.closest('.quiz');
            const correctAnswer = quiz.dataset.correct;
            const selected = quiz.querySelector('input[type="radio"]:checked');
            const feedback = quiz.querySelector('.quiz-feedback');

            if (!selected) {
                feedback.textContent = 'Bitte wähle eine Antwort aus.';
                feedback.className = 'quiz-feedback incorrect';
                return;
            }

            if (selected.value === correctAnswer) {
                feedback.textContent = '✓ Richtig!';
                feedback.className = 'quiz-feedback correct';
            } else {
                feedback.textContent = '✗ Leider falsch. Versuche es nochmal!';
                feedback.className = 'quiz-feedback incorrect';
            }
        }
    </script>

</body>
</html>
